# Copiá este archivo como .env.local para desarrollo, o cargá estas variables en Vercel.
# TODAS son opcionales: sin ninguna, el sitio funciona y el lead queda en los logs.

# Airtable (opción recomendada para guardar los leads)
# AIRTABLE_TOKEN=patXXXXXXXX.XXXXXXXX
# AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# AIRTABLE_TABLE=Leads

# Webhook para guardar el lead (Make, Zapier, n8n, Google Apps Script...)
# LEAD_WEBHOOK_URL=https://hook.us1.make.com/XXXX

# Envío de leads por email con Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# LEAD_EMAIL_TO=info@apolocentrocapilar.com
# LEAD_EMAIL_FROM=Apolo Web <onboarding@resend.dev>
